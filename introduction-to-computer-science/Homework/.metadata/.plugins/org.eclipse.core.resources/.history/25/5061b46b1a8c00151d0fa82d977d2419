    public static void swap(int[] a, int index1, int index2){
        int temp = a[index1];
        a[index1] = a[index2];
        a[index2] = temp;
    }

    public static void main(String[] args){
        System.out.println("hi");
        int[] hi = {1,2,3,4,5};
        int[] numbers = hi;
        System.out.println("Before: " + numbers);
        
        swap(numbers, 0, 1);
        System.out.println("After: " + numbers);
    }

    

