
public class LinkedList<T> {
         public Node<T> front;
         int size;
         
         
         
         public boolean moveTowardFront(T target) {
        	Node<T> ptr = front;
        	Node<T> lag = null;
         	
        	while(ptr != null){
        		if(ptr.data == target){
        			break;
        		}
        		else{
        			ptr = ptr.next;
        			lag = ptr;
        		}
        	}
        	
        	if(ptr == null){
        		return false;
        	}
        	
        	if(lag == null){
        		return true;
        	}
        	
        	System.out.println("one");
        	T temp = lag.data;
        	lag.data = 3;
        	ptr.data = temp;
        	 
        	return true;
         }
         
         public String toString(){
        	 String result = "";
        	 
        	 Node<T> ptr = this.front;
        	 
        	 while(ptr != null){
        		 result = result + ptr.data;
        		 ptr = ptr.next;
        	 }
        	 
        	 return result;
         }
}
